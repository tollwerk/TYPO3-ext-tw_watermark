{
    "name": "tollwerk/tw-watermark",
    "type": "typo3-cms-extension",
    "description": "Automatically add watermarks to all images with copyright or author metadata",
    "license": "LGPL-3.0-or-later",
    "keywords": [
        "TYPO3",
        "extension",
        "article",
        "news"
    ],
    "authors": [
        {
            "name": "Klaus Fiedler",
            "role": "Developer",
            "email": "klaus@tollwerk.de",
            "homepage": "https://tollwerk.de"
        }
    ],
    "homepage": "https://tollwerk.de",
    "support": {
        "issues": "https://github.com/tollwerk/TYPO3-ext-tw_watermark/issues",
        "source": "https://github.com/tollwerk/TYPO3-ext-tw_watermak",
        "docs": "https://github.com/tollwerk/TYPO3-ext-tw_watermark"    },
    "require": {
        "php": ">= 7.4 < 8.5",
        "typo3/cms-core": "^13",
        "typo3/cms-fluid-styled-content": "^13"
    },
    "autoload": {
        "psr-4": {
            "Tollwerk\\TwWatermark\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "tw_watermark"
        },
        "branch-alias": {
            "dev-master": "13.0.x-dev"
        }
    }
}
